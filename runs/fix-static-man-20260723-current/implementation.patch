diff --git a/os/StarryOS/kernel/src/syscall/mm/mmap.rs b/os/StarryOS/kernel/src/syscall/mm/mmap.rs
--- a/os/StarryOS/kernel/src/syscall/mm/mmap.rs
+++ b/os/StarryOS/kernel/src/syscall/mm/mmap.rs
@@ -244,7 +244,9 @@ pub fn sys_mmap(
             _ => false,
         };
         if needs_file_mmap_checks {
-            let (_backend, flags) = fl.file_mmap()?;
+            let (_backend, flags) = fl
+                .file_mmap()
+                .map_err(|_| AxError::PermissionDenied)?;
             if !flags.contains(FileFlags::READ) {
                 return Err(AxError::PermissionDenied);
             }
diff --git a/os/StarryOS/kernel/src/syscall/net/socket.rs b/os/StarryOS/kernel/src/syscall/net/socket.rs
--- a/os/StarryOS/kernel/src/syscall/net/socket.rs
+++ b/os/StarryOS/kernel/src/syscall/net/socket.rs
@@ -101,7 +101,7 @@ pub fn sys_socket(domain: u32, raw_ty: u32, proto: u32) -> AxResult<isize> {
         }
         (AF_INET | AF_INET6, _) | (AF_UNIX, _) | (AF_NETLINK, _) | (AF_VSOCK, _) => {
             warn!("Unsupported socket type: domain: {domain}, ty: {ty}");
-            return Err(AxError::from(LinuxError::ESOCKTNOSUPPORT));
+            return Err(AxError::InvalidInput);
         }
         _ => {
             return Err(AxError::from(LinuxError::EAFNOSUPPORT));
diff --git a/os/StarryOS/kernel/src/syscall/sys.rs b/os/StarryOS/kernel/src/syscall/sys.rs
--- a/os/StarryOS/kernel/src/syscall/sys.rs
+++ b/os/StarryOS/kernel/src/syscall/sys.rs
@@ -952,7 +952,12 @@ pub fn sys_seccomp(op: u32, flags: u32, args: *const ()) -> AxResult<isize> {
                 sync_seccomp_to_thread_group();
             }
         }
-        SECCOMP_GET_ACTION_AVAIL => return seccomp_action_available(args),
+        SECCOMP_GET_ACTION_AVAIL => {
+            if flags != 0 {
