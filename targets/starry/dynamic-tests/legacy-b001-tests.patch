--- /dev/null
+++ b/test-suit/starryos/qemu-smp1/system/syscallguard-b001-fs-side-effect/src/main.c
@@ -0,0 +1,218 @@
+#define _GNU_SOURCE
+#include "test_framework.h"
+
+#include <errno.h>
+#include <fcntl.h>
+#include <limits.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/stat.h>
+#include <sys/syscall.h>
+#include <sys/sysmacros.h>
+#include <sys/types.h>
+#include <sys/wait.h>
+#include <unistd.h>
+
+#ifndef RENAME_NOREPLACE
+#define RENAME_NOREPLACE (1U << 0)
+#endif
+
+static char base[PATH_MAX];
+static char old_cwd[PATH_MAX];
+
+static void join_path(char *out, size_t out_size, const char *name)
+{
+    int ret = snprintf(out, out_size, "%s/%s", base, name);
+    CHECK(ret > 0 && (size_t)ret < out_size, "build test path");
+}
+
+static void rm_tree(const char *path)
+{
+    char cmd[PATH_MAX + 32];
+    int ret = snprintf(cmd, sizeof(cmd), "rm -rf %s", path);
+    if (ret > 0 && (size_t)ret < sizeof(cmd)) {
+        (void)system(cmd);
+    }
+}
+
+static long do_renameat2(int olddirfd, const char *oldpath,
+                         int newdirfd, const char *newpath,
+                         unsigned int flags)
+{
+#ifdef SYS_renameat2
+    return syscall(SYS_renameat2, olddirfd, oldpath, newdirfd, newpath, flags);
+#else
+    errno = ENOSYS;
+    (void)olddirfd;
+    (void)oldpath;
+    (void)newdirfd;
+    (void)newpath;
+    (void)flags;
+    return -1;
+#endif
+}
+
+static void setup(void)
+{
+    CHECK(getcwd(old_cwd, sizeof(old_cwd)) != NULL, "capture old cwd");
+    snprintf(base, sizeof(base), "/tmp/syscallguard-b001-fs-%ld", (long)getpid());
+    rm_tree(base);
+    CHECK_RET(mkdir(base, 0700), 0, "create base directory");
+}
+
+static void test_cwd_and_fchdir(void)
+{
+    char d1[PATH_MAX];
+    char cwd[PATH_MAX];
+    join_path(d1, sizeof(d1), "cwd-target");
+    CHECK_RET(mkdir(d1, 0700), 0, "create cwd target");
+
+    int oldfd = open(old_cwd, O_RDONLY | O_DIRECTORY);
+    CHECK(oldfd >= 0, "open old cwd fd");
+    CHECK_RET(chdir(d1), 0, "chdir changes cwd");
+    CHECK(getcwd(cwd, sizeof(cwd)) != NULL && strcmp(cwd, d1) == 0,
+          "getcwd observes chdir side effect");
+    CHECK_RET(fchdir(oldfd), 0, "fchdir restores cwd");
+    CHECK(getcwd(cwd, sizeof(cwd)) != NULL && strcmp(cwd, old_cwd) == 0,
+          "getcwd observes fchdir side effect");
+    if (oldfd >= 0) {
+        CHECK_RET(close(oldfd), 0, "close old cwd fd");
+    }
+}
+
+static void test_creation_and_removal(void)
+{
+    char p[PATH_MAX];
+    struct stat st;
+    int dfd = open(base, O_RDONLY | O_DIRECTORY);
+    CHECK(dfd >= 0, "open base dirfd");
+
+    join_path(p, sizeof(p), "mkdir-plain");
+    CHECK_RET(mkdir(p, 0755), 0, "mkdir creates directory");
+    CHECK_RET(stat(p, &st), 0, "stat mkdir result");
+    CHECK(S_ISDIR(st.st_mode), "mkdir result is directory");
+
+    CHECK_RET(mkdirat(dfd, "mkdir-at", 0755), 0, "mkdirat creates directory");
+    CHECK_RET(fstatat(dfd, "mkdir-at", &st, 0), 0, "fstatat mkdirat result");
+    CHECK(S_ISDIR(st.st_mode), "mkdirat result is directory");
+
+    join_path(p, sizeof(p), "fifo-plain");
+    CHECK_RET(mknod(p, S_IFIFO | 0600, makedev(0, 0)), 0, "mknod creates fifo");
+    CHECK_RET(lstat(p, &st), 0, "lstat mknod fifo");
+    CHECK(S_ISFIFO(st.st_mode), "mknod result is fifo");
+
+    CHECK_RET(mknodat(dfd, "fifo-at", S_IFIFO | 0600, makedev(0, 0)), 0,
+              "mknodat creates fifo");
+    CHECK_RET(fstatat(dfd, "fifo-at", &st, AT_SYMLINK_NOFOLLOW), 0,
+              "fstatat mknodat fifo");
+    CHECK(S_ISFIFO(st.st_mode), "mknodat result is fifo");
+
+    CHECK_RET(unlinkat(dfd, "fifo-at", 0), 0, "unlinkat removes fifo-at");
+    CHECK_RET(unlink(p), 0, "unlink removes fifo-plain");
+    CHECK_RET(unlinkat(dfd, "mkdir-at", AT_REMOVEDIR), 0, "unlinkat removes directory");
+    join_path(p, sizeof(p), "mkdir-plain");
+    CHECK_RET(rmdir(p), 0, "rmdir removes directory");
+
+    CHECK_RET(close(dfd), 0, "close base dirfd");
+}
+
+static void test_links_symlinks_and_rename(void)
+{
+    char src[PATH_MAX];
+    char dst[PATH_MAX];
+    char at_dst[PATH_MAX];
+    char buf[64];
+    struct stat st;
+    int dfd = open(base, O_RDONLY | O_DIRECTORY);
+    CHECK(dfd >= 0, "open base dirfd for link tests");
+
+    join_path(src, sizeof(src), "link-src");
+    int fd = open(src, O_CREAT | O_WRONLY | O_TRUNC, 0644);
+    CHECK(fd >= 0, "create hard-link source");
+    if (fd >= 0) {
+        CHECK_RET(write(fd, "x", 1), 1, "write hard-link source");
+        CHECK_RET(close(fd), 0, "close hard-link source");
+    }
+
+    join_path(dst, sizeof(dst), "link-dst");
+    CHECK_RET(link(src, dst), 0, "link creates hard link");
+    CHECK_RET(stat(src, &st), 0, "stat hard-link source");
+    CHECK(st.st_nlink >= 2, "hard link count reflects link side effect");
+    CHECK_RET(linkat(dfd, "link-src", dfd, "link-at-dst", 0), 0, "linkat creates hard link");
+
+    join_path(dst, sizeof(dst), "sym-dst");
+    CHECK_RET(symlink("target-value", dst), 0, "symlink creates link");
+    ssize_t n = readlink(dst, buf, sizeof(buf) - 1);
+    CHECK(n == 12, "readlink length for symlink");
+    if (n >= 0) {
+        buf[n] = 0;
+        CHECK(strcmp(buf, "target-value") == 0, "readlink observes symlink target");
+    }
+    CHECK_RET(symlinkat("target-at", dfd, "sym-at-dst"), 0, "symlinkat creates link");
+
+    join_path(dst, sizeof(dst), "renamed");
+    CHECK_RET(rename(src, dst), 0, "rename moves source");
+    CHECK_RET(stat(dst, &st), 0, "rename destination exists");
+    errno = 0;
+    CHECK(stat(src, &st) == -1 && errno == ENOENT, "rename source disappears");
+
+    CHECK_RET(renameat(dfd, "link-at-dst", dfd, "renameat-dst"), 0,
+              "renameat moves source");
+    CHECK_RET(fstatat(dfd, "renameat-dst", &st, 0), 0, "renameat destination exists");
+
+    int fd1 = openat(dfd, "rename2-src", O_CREAT | O_WRONLY | O_TRUNC, 0644);
+    int fd2 = openat(dfd, "rename2-existing", O_CREAT | O_WRONLY | O_TRUNC, 0644);
+    CHECK(fd1 >= 0 && fd2 >= 0, "create renameat2 files");
+    if (fd1 >= 0) {
+        close(fd1);
+    }
+    if (fd2 >= 0) {
+        close(fd2);
+    }
+    CHECK_ERR(do_renameat2(dfd, "rename2-src", dfd, "rename2-existing", RENAME_NOREPLACE),
+              EEXIST, "renameat2 RENAME_NOREPLACE keeps existing destination");
+    CHECK_RET(do_renameat2(dfd, "rename2-src", dfd, "rename2-new", RENAME_NOREPLACE), 0,
+              "renameat2 RENAME_NOREPLACE creates new destination");
+    CHECK_RET(fstatat(dfd, "rename2-new", &st, 0), 0, "renameat2 destination exists");
+
+    join_path(at_dst, sizeof(at_dst), "renameat-dst");
+    unlink(at_dst);
+    CHECK_RET(close(dfd), 0, "close base dirfd for link tests");
+}
+
+static void test_chroot_child(void)
+{
+    char root_dir[PATH_MAX];
+    join_path(root_dir, sizeof(root_dir), "root-child");
+    CHECK_RET(mkdir(root_dir, 0755), 0, "create child chroot directory");
+
+    pid_t child = fork();
+    CHECK(child >= 0, "fork chroot child");
+    if (child == 0) {
+        char cwd[PATH_MAX];
+        CHECK_RET(chroot(root_dir), 0, "child chroot succeeds");
+        CHECK_RET(chdir("/"), 0, "child chdir after chroot");
+        CHECK(getcwd(cwd, sizeof(cwd)) != NULL && strcmp(cwd, "/") == 0,
+              "child getcwd observes new root");
+        exit(__fail > 0 ? 1 : 0);
+    }
+    if (child > 0) {
+        int status = 0;
+        CHECK_RET(waitpid(child, &status, 0), child, "wait chroot child");
+        CHECK(WIFEXITED(status) && WEXITSTATUS(status) == 0, "chroot child checks passed");
+    }
+}
+
+int main(void)
+{
+    TEST_START("SyscallGuard b001 filesystem side effects");
+    setup();
+    test_cwd_and_fchdir();
+    test_creation_and_removal();
+    test_links_symlinks_and_rename();
+    test_chroot_child();
+    CHECK_RET(chdir(old_cwd), 0, "restore cwd before cleanup");
+    rm_tree(base);
+    TEST_DONE();
+}
