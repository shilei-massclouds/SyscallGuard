--- /dev/null
+++ b/test-suit/starryos/qemu-smp1/system/syscallguard-b001-permission-matrix/src/main.c
@@ -0,0 +1,136 @@
+#define _GNU_SOURCE
+#include "test_framework.h"
+
+#include <errno.h>
+#include <fcntl.h>
+#include <limits.h>
+#include <signal.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/stat.h>
+#include <sys/sysmacros.h>
+#include <sys/types.h>
+#include <sys/wait.h>
+#include <unistd.h>
+
+static char base[PATH_MAX];
+
+static void join_path(char *out, size_t out_size, const char *name)
+{
+    int ret = snprintf(out, out_size, "%s/%s", base, name);
+    CHECK(ret > 0 && (size_t)ret < out_size, "build test path");
+}
+
+static void rm_tree(const char *path)
+{
+    char cmd[PATH_MAX + 32];
+    int ret = snprintf(cmd, sizeof(cmd), "rm -rf %s", path);
+    if (ret > 0 && (size_t)ret < sizeof(cmd)) {
+        (void)system(cmd);
+    }
+}
+
+static void setup_tree(void)
+{
+    char p[PATH_MAX];
+
+    snprintf(base, sizeof(base), "/tmp/syscallguard-b001-perm-%ld", (long)getpid());
+    rm_tree(base);
+    CHECK_RET(mkdir(base, 0777), 0, "create base directory");
+    CHECK_RET(chmod(base, 0777), 0, "make base writable for child");
+
+    join_path(p, sizeof(p), "no_search");
+    CHECK_RET(mkdir(p, 0666), 0, "create non-searchable directory");
+    CHECK_RET(chmod(p, 0666), 0, "remove search permission");
+
+    join_path(p, sizeof(p), "no_write");
+    CHECK_RET(mkdir(p, 0555), 0, "create non-writable directory");
+    CHECK_RET(chmod(p, 0555), 0, "remove write permission");
+
+    char file[PATH_MAX];
+    join_path(file, sizeof(file), "no_write/file");
+    int fd = open(file, O_CREAT | O_WRONLY | O_TRUNC, 0666);
+    CHECK(fd >= 0, "create file in non-writable directory before dropping uid");
+    if (fd >= 0) {
+        CHECK_RET(write(fd, "x", 1), 1, "write setup file");
+        CHECK_RET(close(fd), 0, "close setup file");
+    }
+
+    join_path(p, sizeof(p), "writable");
+    CHECK_RET(mkdir(p, 0777), 0, "create writable directory");
+    CHECK_RET(chmod(p, 0777), 0, "make writable directory world-writable");
+
+    join_path(file, sizeof(file), "writable/source");
+    fd = open(file, O_CREAT | O_WRONLY | O_TRUNC, 0666);
+    CHECK(fd >= 0, "create rename source before dropping uid");
+    if (fd >= 0) {
+        CHECK_RET(close(fd), 0, "close rename source");
+    }
+
+    join_path(p, sizeof(p), "chroot-target");
+    CHECK_RET(mkdir(p, 0755), 0, "create chroot target");
+}
+
+static void child_permission_checks(void)
+{
+    char p[PATH_MAX];
+    char src[PATH_MAX];
+    char dst[PATH_MAX];
+
+    errno = 0;
+    CHECK(setgid(65534) == 0 || errno == EPERM, "drop gid or report unavailable privilege");
+    errno = 0;
+    CHECK(setuid(65534) == 0 || errno == EPERM, "drop uid or report unavailable privilege");
+    CHECK(geteuid() != 0, "permission matrix child runs without root privileges");
+
+    join_path(p, sizeof(p), "no_search/mkdir-child");
+    CHECK_ERR(mkdir(p, 0700), EACCES, "mkdir under parent without search permission -> EACCES");
+
+    join_path(p, sizeof(p), "no_write/unlink-target");
+    CHECK_ERR(unlink(p), EACCES, "unlink in parent without write permission -> EACCES");
+
+    join_path(src, sizeof(src), "no_write/file");
+    join_path(dst, sizeof(dst), "no_write/hardlink");
+    CHECK_ERR(link(src, dst), EACCES, "link into parent without write permission -> EACCES");
+
+    join_path(dst, sizeof(dst), "no_write/symlink");
+    CHECK_ERR(symlink("target", dst), EACCES, "symlink into parent without write permission -> EACCES");
+
+    join_path(src, sizeof(src), "writable/source");
+    join_path(dst, sizeof(dst), "no_write/renamed");
+    CHECK_ERR(rename(src, dst), EACCES, "rename into parent without write permission -> EACCES");
+
+    join_path(dst, sizeof(dst), "no_write/fifo");
+    CHECK_ERR(mknod(dst, S_IFIFO | 0600, makedev(0, 0)), EACCES,
+              "mknod in parent without write permission -> EACCES");
+
+    join_path(dst, sizeof(dst), "chroot-target");
+    CHECK_ERR(chroot(dst), EPERM, "unprivileged chroot -> EPERM");
+
+    exit(__fail > 0 ? 1 : 0);
+}
+
+static void run_child(void)
+{
+    pid_t child = fork();
+    CHECK(child >= 0, "fork permission child");
+    if (child == 0) {
+        child_permission_checks();
+    }
+    if (child > 0) {
+        int status = 0;
+        CHECK_RET(waitpid(child, &status, 0), child, "wait for permission child");
+        CHECK(WIFEXITED(status) && WEXITSTATUS(status) == 0,
+              "permission child checks passed");
+    }
+}
+
+int main(void)
+{
+    TEST_START("SyscallGuard b001 permission matrix");
+    setup_tree();
+    run_child();
+    rm_tree(base);
+    TEST_DONE();
+}
