+++ b/test-suit/starryos/qemu-smp1/system/syscallguard-b001-fd-type-matrix/src/main.c
@@ -0,0 +1,159 @@
+#define _GNU_SOURCE
+#include "test_framework.h"
+
+#include <errno.h>
+#include <fcntl.h>
+#include <limits.h>
+#include <stdint.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/ioctl.h>
+#include <sys/stat.h>
+#include <sys/syscall.h>
+#include <unistd.h>
+
+static char base[PATH_MAX];
+
+static long do_getdents64(int fd, void *buf, size_t size)
+{
+    return syscall(SYS_getdents64, fd, buf, size);
+}
+
+static void rm_tree(const char *path)
+{
+    char cmd[PATH_MAX + 32];
+    int ret = snprintf(cmd, sizeof(cmd), "rm -rf %s", path);
+    if (ret > 0 && (size_t)ret < sizeof(cmd)) {
+        (void)system(cmd);
+    }
+}
+
+static void setup(void)
+{
+    char path[PATH_MAX];
+    snprintf(base, sizeof(base), "/tmp/syscallguard-b001-fd-%ld", (long)getpid());
+    rm_tree(base);
+    CHECK_RET(mkdir(base, 0700), 0, "create base directory");
+    int ret = snprintf(path, sizeof(path), "%s/file", base);
+    CHECK(ret > 0 && (size_t)ret < sizeof(path), "build regular file path");
+    int fd = open(path, O_CREAT | O_RDWR | O_TRUNC, 0644);
+    CHECK(fd >= 0, "create regular file");
+    if (fd >= 0) {
+        CHECK_RET(close(fd), 0, "close regular file");
+    }
+}
+
+static void test_fchdir_matrix(void)
+{
+    char path[PATH_MAX];
+    char old_cwd[PATH_MAX];
+    CHECK(getcwd(old_cwd, sizeof(old_cwd)) != NULL, "capture cwd for fchdir matrix");
+
+    CHECK_ERR(fchdir(-1), EBADF, "fchdir invalid fd -> EBADF");
+
+    int dfd = open(base, O_RDONLY | O_DIRECTORY);
+    CHECK(dfd >= 0, "open directory fd");
+    CHECK_RET(fchdir(dfd), 0, "fchdir accepts directory fd");
+    CHECK_RET(chdir(old_cwd), 0, "restore cwd after fchdir success");
+
+    int ret = snprintf(path, sizeof(path), "%s/file", base);
+    CHECK(ret > 0 && (size_t)ret < sizeof(path), "build file path for fchdir");
+    int ffd = open(path, O_RDONLY);
+    CHECK(ffd >= 0, "open regular file fd");
+    CHECK_ERR(fchdir(ffd), ENOTDIR, "fchdir regular file fd -> ENOTDIR");
+
+    int closed = dup(dfd);
+    CHECK(closed >= 0, "dup directory fd for closed-fd probe");
+    CHECK_RET(close(closed), 0, "close duplicated fd");
+    CHECK_ERR(fchdir(closed), EBADF, "fchdir closed fd -> EBADF");
+
+    if (ffd >= 0) {
+        CHECK_RET(close(ffd), 0, "close regular file fd");
+    }
+    if (dfd >= 0) {
+        CHECK_RET(close(dfd), 0, "close directory fd");
+    }
+}
+
+static void test_getdents64_matrix(void)
+{
+    char path[PATH_MAX];
+    char buf[512];
+
+    CHECK_ERR(do_getdents64(-1, buf, sizeof(buf)), EBADF,
+              "getdents64 invalid fd -> EBADF");
+
+    int dfd = open(base, O_RDONLY | O_DIRECTORY);
+    CHECK(dfd >= 0, "open directory fd for getdents64");
+    errno = 0;
+    long nread = do_getdents64(dfd, buf, sizeof(buf));
+    CHECK(nread >= 0, "getdents64 accepts directory fd");
+
+    int ret = snprintf(path, sizeof(path), "%s/file", base);
+    CHECK(ret > 0 && (size_t)ret < sizeof(path), "build file path for getdents64");
+    int ffd = open(path, O_RDONLY);
+    CHECK(ffd >= 0, "open regular file fd for getdents64");
+    CHECK_ERR(do_getdents64(ffd, buf, sizeof(buf)), ENOTDIR,
+              "getdents64 regular file fd -> ENOTDIR");
+
+    int pipefd[2];
+    CHECK_RET(pipe(pipefd), 0, "create pipe for getdents64 fd type");
+    CHECK_ERR(do_getdents64(pipefd[0], buf, sizeof(buf)), ENOTDIR,
+              "getdents64 pipe fd -> ENOTDIR");
+
+    int closed = dup(dfd);
+    CHECK(closed >= 0, "dup fd for closed getdents64 probe");
+    CHECK_RET(close(closed), 0, "close duplicated getdents64 fd");
+    CHECK_ERR(do_getdents64(closed, buf, sizeof(buf)), EBADF,
+              "getdents64 closed fd -> EBADF");
+
+    if (pipefd[0] >= 0) {
+        close(pipefd[0]);
+    }
+    if (pipefd[1] >= 0) {
+        close(pipefd[1]);
+    }
+    if (ffd >= 0) {
+        close(ffd);
+    }
+    if (dfd >= 0) {
+        close(dfd);
+    }
+}
+
+static void test_ioctl_matrix(void)
+{
+    int value = 0;
+    CHECK_ERR(ioctl(-1, FIONREAD, &value), EBADF, "ioctl invalid fd -> EBADF");
+
+    int pipefd[2];
+    CHECK_RET(pipe(pipefd), 0, "create pipe for ioctl FIONREAD");
+    CHECK_RET(write(pipefd[1], "abc", 3), 3, "write bytes for FIONREAD");
+    value = 0;
+    CHECK_RET(ioctl(pipefd[0], FIONREAD, &value), 0, "ioctl FIONREAD accepts pipe fd");
+    CHECK(value == 3, "ioctl FIONREAD reports pipe byte count");
+
+    int closed = dup(pipefd[0]);
+    CHECK(closed >= 0, "dup pipe fd for ioctl closed-fd probe");
+    CHECK_RET(close(closed), 0, "close duplicated pipe fd");
+    CHECK_ERR(ioctl(closed, FIONREAD, &value), EBADF, "ioctl closed fd -> EBADF");
+
+    if (pipefd[0] >= 0) {
+        close(pipefd[0]);
+    }
+    if (pipefd[1] >= 0) {
+        close(pipefd[1]);
+    }
+}
+
+int main(void)
+{
+    TEST_START("SyscallGuard b001 fd type matrix");
+    setup();
+    test_fchdir_matrix();
+    test_getdents64_matrix();
+    test_ioctl_matrix();
+    rm_tree(base);
+    TEST_DONE();
+}
