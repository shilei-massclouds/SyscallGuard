--- /dev/null
+++ b/test-suit/starryos/qemu-smp1/system/syscallguard-b001-userptr-efault/src/main.c
@@ -0,0 +1,130 @@
+#define _GNU_SOURCE
+#include "test_framework.h"
+
+#include <errno.h>
+#include <fcntl.h>
+#include <limits.h>
+#include <stdint.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/ioctl.h>
+#include <sys/mman.h>
+#include <sys/stat.h>
+#include <sys/syscall.h>
+#include <unistd.h>
+
+static char base[PATH_MAX];
+
+static long do_getcwd_sys(void *buf, size_t size)
+{
+    return syscall(SYS_getcwd, buf, size);
+}
+
+static long do_getdents64(int fd, void *buf, size_t size)
+{
+    return syscall(SYS_getdents64, fd, buf, size);
+}
+
+static void *make_unmapped_page(void)
+{
+    void *page = mmap(NULL, 4096, PROT_READ | PROT_WRITE,
+                      MAP_PRIVATE | MAP_ANONYMOUS, -1, 0);
+    if (page == MAP_FAILED) {
+        return NULL;
+    }
+    CHECK_RET(munmap(page, 4096), 0, "unmap temporary page for EFAULT probe");
+    return page;
+}
+
+static void rm_tree(const char *path)
+{
+    char cmd[PATH_MAX + 32];
+    int ret = snprintf(cmd, sizeof(cmd), "rm -rf %s", path);
+    if (ret > 0 && (size_t)ret < sizeof(cmd)) {
+        (void)system(cmd);
+    }
+}
+
+static void setup(void)
+{
+    char p[PATH_MAX];
+    snprintf(base, sizeof(base), "/tmp/syscallguard-b001-userptr-%ld", (long)getpid());
+    rm_tree(base);
+    CHECK_RET(mkdir(base, 0700), 0, "create base directory");
+    int ret = snprintf(p, sizeof(p), "%s/entry", base);
+    CHECK(ret > 0 && (size_t)ret < sizeof(p), "build entry path");
+    int fd = open(p, O_CREAT | O_WRONLY | O_TRUNC, 0644);
+    CHECK(fd >= 0, "create directory entry");
+    if (fd >= 0) {
+        CHECK_RET(close(fd), 0, "close directory entry");
+    }
+}
+
+static void test_getcwd_bad_pointers(void)
+{
+    char small[1];
+    void *bad = make_unmapped_page();
+    void *readonly = mmap(NULL, 4096, PROT_READ, MAP_PRIVATE | MAP_ANONYMOUS, -1, 0);
+
+    CHECK_ERR(do_getcwd_sys(NULL, PATH_MAX), EFAULT, "getcwd NULL output pointer -> EFAULT");
+    if (bad != NULL) {
+        CHECK_ERR(do_getcwd_sys(bad, PATH_MAX), EFAULT,
+                  "getcwd unmapped output pointer -> EFAULT");
+    }
+    CHECK(readonly != MAP_FAILED, "map read-only output page");
+    if (readonly != MAP_FAILED) {
+        CHECK_ERR(do_getcwd_sys(readonly, 4096), EFAULT,
+                  "getcwd read-only output page -> EFAULT");
+        CHECK_RET(munmap(readonly, 4096), 0, "unmap read-only output page");
+    }
+
+    CHECK_ERR(do_getcwd_sys(small, sizeof(small)), ERANGE,
+              "getcwd too-small valid buffer -> ERANGE");
+}
+
+static void test_getdents64_bad_pointers(void)
+{
+    void *bad = make_unmapped_page();
+    int fd = open(base, O_RDONLY | O_DIRECTORY);
+    CHECK(fd >= 0, "open directory for getdents64 EFAULT probes");
+    if (fd < 0) {
+        return;
+    }
+
+    CHECK_ERR(do_getdents64(fd, NULL, 4096), EFAULT,
+              "getdents64 NULL output pointer -> EFAULT");
+    if (bad != NULL) {
+        CHECK_ERR(do_getdents64(fd, bad, 4096), EFAULT,
+                  "getdents64 unmapped output pointer -> EFAULT");
+    }
+    CHECK_RET(close(fd), 0, "close directory after getdents64 EFAULT probes");
+}
+
+static void test_ioctl_bad_pointer(void)
+{
+    int pipefd[2];
+    void *bad = make_unmapped_page();
+    CHECK_RET(pipe(pipefd), 0, "create pipe for ioctl EFAULT probe");
+    if (bad != NULL) {
+        CHECK_ERR(ioctl(pipefd[0], FIONREAD, bad), EFAULT,
+                  "ioctl FIONREAD bad output pointer -> EFAULT");
+    }
+    if (pipefd[0] >= 0) {
+        close(pipefd[0]);
+    }
+    if (pipefd[1] >= 0) {
+        close(pipefd[1]);
+    }
+}
+
+int main(void)
+{
+    TEST_START("SyscallGuard b001 user pointer EFAULT");
+    setup();
+    test_getcwd_bad_pointers();
+    test_getdents64_bad_pointers();
+    test_ioctl_bad_pointer();
+    rm_tree(base);
+    TEST_DONE();
+}
