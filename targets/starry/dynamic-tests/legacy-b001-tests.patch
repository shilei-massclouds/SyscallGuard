--- /dev/null
+++ b/test-suit/starryos/qemu-smp1/system/syscallguard-b001-dirent-enumeration/src/main.c
@@ -0,0 +1,137 @@
+#define _GNU_SOURCE
+#include "test_framework.h"
+
+#include <dirent.h>
+#include <errno.h>
+#include <fcntl.h>
+#include <limits.h>
+#include <stdint.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/stat.h>
+#include <sys/syscall.h>
+#include <unistd.h>
+
+struct linux_dirent64 {
+    uint64_t d_ino;
+    int64_t d_off;
+    unsigned short d_reclen;
+    unsigned char d_type;
+    char d_name[];
+};
+
+static char base[PATH_MAX];
+
+static long do_getdents64(int fd, void *buf, size_t size)
+{
+    return syscall(SYS_getdents64, fd, buf, size);
+}
+
+static void rm_tree(const char *path)
+{
+    char cmd[PATH_MAX + 32];
+    int ret = snprintf(cmd, sizeof(cmd), "rm -rf %s", path);
+    if (ret > 0 && (size_t)ret < sizeof(cmd)) {
+        (void)system(cmd);
+    }
+}
+
+static void setup(void)
+{
+    char path[PATH_MAX];
+    snprintf(base, sizeof(base), "/tmp/syscallguard-b001-dirent-%ld", (long)getpid());
+    rm_tree(base);
+    CHECK_RET(mkdir(base, 0700), 0, "create base directory");
+
+    int ret = snprintf(path, sizeof(path), "%s/alpha", base);
+    CHECK(ret > 0 && (size_t)ret < sizeof(path), "build alpha path");
+    int fd = open(path, O_CREAT | O_WRONLY | O_TRUNC, 0644);
+    CHECK(fd >= 0, "create alpha");
+    if (fd >= 0) {
+        CHECK_RET(close(fd), 0, "close alpha");
+    }
+
+    ret = snprintf(path, sizeof(path), "%s/beta", base);
+    CHECK(ret > 0 && (size_t)ret < sizeof(path), "build beta path");
+    fd = open(path, O_CREAT | O_WRONLY | O_TRUNC, 0644);
+    CHECK(fd >= 0, "create beta");
+    if (fd >= 0) {
+        CHECK_RET(close(fd), 0, "close beta");
+    }
+
+    ret = snprintf(path, sizeof(path), "%s/subdir", base);
+    CHECK(ret > 0 && (size_t)ret < sizeof(path), "build subdir path");
+    CHECK_RET(mkdir(path, 0700), 0, "create subdir");
+}
+
+static void parse_dirents(char *buf, long nread, int *saw_alpha,
+                          int *saw_beta, int *saw_subdir)
+{
+    long pos = 0;
+    while (pos < nread) {
+        struct linux_dirent64 *d = (struct linux_dirent64 *)(buf + pos);
+        CHECK(d->d_reclen >= sizeof(*d) + 1, "dirent reclen has room for header and name");
+        CHECK(d->d_reclen > 0 && pos + d->d_reclen <= nread, "dirent reclen stays inside buffer");
+        CHECK(d->d_off >= 0, "dirent d_off is non-negative");
+        CHECK(memchr(d->d_name, 0, d->d_reclen - sizeof(*d)) != NULL,
+              "dirent name is nul-terminated inside record");
+
+        if (strcmp(d->d_name, "alpha") == 0) {
+            *saw_alpha = 1;
+            CHECK(d->d_type == DT_REG || d->d_type == DT_UNKNOWN,
+                  "alpha d_type is regular or unknown");
+        } else if (strcmp(d->d_name, "beta") == 0) {
+            *saw_beta = 1;
+            CHECK(d->d_type == DT_REG || d->d_type == DT_UNKNOWN,
+                  "beta d_type is regular or unknown");
+        } else if (strcmp(d->d_name, "subdir") == 0) {
+            *saw_subdir = 1;
+            CHECK(d->d_type == DT_DIR || d->d_type == DT_UNKNOWN,
+                  "subdir d_type is directory or unknown");
+        }
+        pos += d->d_reclen;
+    }
+    CHECK(pos == nread, "dirent parser consumed exactly nread bytes");
+}
+
+static void test_enumeration(void)
+{
+    char buf[1024];
+    int saw_alpha = 0;
+    int saw_beta = 0;
+    int saw_subdir = 0;
+    int fd = open(base, O_RDONLY | O_DIRECTORY);
+    CHECK(fd >= 0, "open directory for getdents64");
+    if (fd < 0) {
+        return;
+    }
+
+    CHECK_ERR(do_getdents64(fd, buf, 1), EINVAL, "undersized getdents64 buffer -> EINVAL");
+    CHECK_RET(lseek(fd, 0, SEEK_SET), 0, "rewind directory after EINVAL probe");
+
+    for (;;) {
+        errno = 0;
+        long nread = do_getdents64(fd, buf, sizeof(buf));
+        CHECK(nread >= 0, "getdents64 returns non-negative byte count");
+        if (nread <= 0) {
+            CHECK(nread == 0, "getdents64 eventually reaches EOF");
+            break;
+        }
+        parse_dirents(buf, nread, &saw_alpha, &saw_beta, &saw_subdir);
+    }
+
+    CHECK(saw_alpha, "getdents64 returned alpha entry");
+    CHECK(saw_beta, "getdents64 returned beta entry");
+    CHECK(saw_subdir, "getdents64 returned subdir entry");
+    CHECK_RET(close(fd), 0, "close directory fd");
+}
+
+int main(void)
+{
+    TEST_START("SyscallGuard b001 dirent enumeration");
+    setup();
+    test_enumeration();
+    rm_tree(base);
+    TEST_DONE();
+}
