+#define _GNU_SOURCE
+#include "test_framework.h"
+
+#include <errno.h>
+#include <fcntl.h>
+#include <limits.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/stat.h>
+#include <sys/sysmacros.h>
+#include <sys/types.h>
+#include <unistd.h>
+
+static char base[PATH_MAX];
+
+static void join_path(char *out, size_t out_size, const char *name)
+{
+    int ret = snprintf(out, out_size, "%s/%s", base, name);
+    CHECK(ret > 0 && (size_t)ret < out_size, "build test path");
+}
+
+static void rm_tree(const char *path)
+{
+    char cmd[PATH_MAX + 32];
+    int ret = snprintf(cmd, sizeof(cmd), "rm -rf %s", path);
+    if (ret > 0 && (size_t)ret < sizeof(cmd)) {
+        (void)system(cmd);
+    }
+}
+
+static void setup(void)
+{
+    snprintf(base, sizeof(base), "/tmp/syscallguard-b001-mode-%ld", (long)getpid());
+    rm_tree(base);
+    CHECK_RET(mkdir(base, 0700), 0, "create base directory");
+}
+
+static void check_metadata(const char *path, mode_t expected_type,
+                           mode_t expected_mode, const char *msg)
+{
+    struct stat st;
+    CHECK_RET(lstat(path, &st), 0, msg);
+    CHECK((st.st_mode & S_IFMT) == expected_type, "created node has expected type");
+    CHECK((st.st_mode & 0777) == expected_mode, "created node honors requested mode and umask");
+    CHECK(st.st_uid == geteuid(), "created node uid matches process euid");
+    CHECK(st.st_gid == getegid(), "created node gid matches process egid");
+}
+
+static void test_mkdir_modes(void)
+{
+    char p[PATH_MAX];
+    mode_t saved = umask(0027);
+    int dfd = open(base, O_RDONLY | O_DIRECTORY);
+    CHECK(dfd >= 0, "open base dirfd for mkdir metadata");
+
+    join_path(p, sizeof(p), "mkdir-plain");
+    CHECK_RET(mkdir(p, 0777), 0, "mkdir with umask 0027");
+    check_metadata(p, S_IFDIR, 0750, "lstat mkdir metadata");
+
+    CHECK_RET(mkdirat(dfd, "mkdir-at", 0777), 0, "mkdirat with umask 0027");
+    join_path(p, sizeof(p), "mkdir-at");
+    check_metadata(p, S_IFDIR, 0750, "lstat mkdirat metadata");
+
+    if (dfd >= 0) {
+        CHECK_RET(close(dfd), 0, "close mkdir metadata dirfd");
+    }
+    umask(saved);
+}
+
+static void test_mknod_modes(void)
+{
+    char p[PATH_MAX];
+    mode_t saved = umask(0077);
+    int dfd = open(base, O_RDONLY | O_DIRECTORY);
+    CHECK(dfd >= 0, "open base dirfd for mknod metadata");
+
+    join_path(p, sizeof(p), "fifo-plain");
+    CHECK_RET(mknod(p, S_IFIFO | 0666, makedev(0, 0)), 0, "mknod FIFO with umask 0077");
+    check_metadata(p, S_IFIFO, 0600, "lstat mknod FIFO metadata");
+
+    CHECK_RET(mknodat(dfd, "fifo-at", S_IFIFO | 0666, makedev(0, 0)), 0,
+              "mknodat FIFO with umask 0077");
+    join_path(p, sizeof(p), "fifo-at");
+    check_metadata(p, S_IFIFO, 0600, "lstat mknodat FIFO metadata");
+
+    if (dfd >= 0) {
+        CHECK_RET(close(dfd), 0, "close mknod metadata dirfd");
+    }
+    umask(saved);
+}
+
+static void test_mknod_rejects_directory_type(void)
+{
+    char p[PATH_MAX];
+    int dfd = open(base, O_RDONLY | O_DIRECTORY);
+    CHECK(dfd >= 0, "open base dirfd for directory mknod rejection");
+
+    join_path(p, sizeof(p), "dir-node-plain");
+    CHECK_ERR(mknod(p, S_IFDIR | 0700, makedev(0, 0)), EPERM,
+              "mknod S_IFDIR request -> EPERM");
+    CHECK_ERR(mknodat(dfd, "dir-node-at", S_IFDIR | 0700, makedev(0, 0)), EPERM,
+              "mknodat S_IFDIR request -> EPERM");
+
+    if (dfd >= 0) {
+        CHECK_RET(close(dfd), 0, "close directory mknod rejection dirfd");
+    }
+}
+
+int main(void)
+{
+    TEST_START("SyscallGuard b001 mode uid gid behavior");
+    setup();
+    test_mkdir_modes();
+    test_mknod_modes();
+    test_mknod_rejects_directory_type();
+    rm_tree(base);
+    TEST_DONE();
+}
