+++ b/test-suit/starryos/qemu-smp1/system/syscallguard-b001-path-errno-priority/src/main.c
@@ -0,0 +1,167 @@
+#define _GNU_SOURCE
+#include "test_framework.h"
+
+#include <errno.h>
+#include <fcntl.h>
+#include <limits.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/stat.h>
+#include <sys/syscall.h>
+#include <sys/sysmacros.h>
+#include <unistd.h>
+
+#ifndef RENAME_NOREPLACE
+#define RENAME_NOREPLACE (1U << 0)
+#endif
+
+static char base[PATH_MAX];
+
+static long do_renameat2(int olddirfd, const char *oldpath,
+                         int newdirfd, const char *newpath,
+                         unsigned int flags)
+{
+#ifdef SYS_renameat2
+    return syscall(SYS_renameat2, olddirfd, oldpath, newdirfd, newpath, flags);
+#else
+    errno = ENOSYS;
+    (void)olddirfd;
+    (void)oldpath;
+    (void)newdirfd;
+    (void)newpath;
+    (void)flags;
+    return -1;
+#endif
+}
+
+static void join_path(char *out, size_t out_size, const char *name)
+{
+    int ret = snprintf(out, out_size, "%s/%s", base, name);
+    CHECK(ret > 0 && (size_t)ret < out_size, "build test path");
+}
+
+static void rm_tree(const char *path)
+{
+    char cmd[PATH_MAX + 32];
+    int ret = snprintf(cmd, sizeof(cmd), "rm -rf %s", path);
+    if (ret > 0 && (size_t)ret < sizeof(cmd)) {
+        (void)system(cmd);
+    }
+}
+
+static void setup(void)
+{
+    char p[PATH_MAX];
+    snprintf(base, sizeof(base), "/tmp/syscallguard-b001-path-%ld", (long)getpid());
+    rm_tree(base);
+    CHECK_RET(mkdir(base, 0700), 0, "create base directory");
+
+    join_path(p, sizeof(p), "file");
+    int fd = open(p, O_CREAT | O_WRONLY | O_TRUNC, 0644);
+    CHECK(fd >= 0, "create regular file");
+    if (fd >= 0) {
+        CHECK_RET(close(fd), 0, "close regular file");
+    }
+
+    join_path(p, sizeof(p), "existing-dir");
+    CHECK_RET(mkdir(p, 0700), 0, "create existing directory");
+}
+
+static void make_long_name(char *buf, size_t size)
+{
+    memset(buf, 'a', size - 1);
+    buf[size - 1] = 0;
+}
+
+static void test_path_lengths(void)
+{
+    char long_name[PATH_MAX + 64];
+    make_long_name(long_name, sizeof(long_name));
+    CHECK_ERR(mkdir(long_name, 0700), ENAMETOOLONG,
+              "mkdir overlong component -> ENAMETOOLONG");
+    CHECK_ERR(chdir(long_name), ENAMETOOLONG,
+              "chdir overlong component -> ENAMETOOLONG");
+}
+
+static void test_lookup_errno_priority(void)
+{
+    char p[PATH_MAX];
+    char q[PATH_MAX];
+
+    join_path(p, sizeof(p), "missing");
+    CHECK_ERR(unlink(p), ENOENT, "unlink missing final component -> ENOENT");
+    CHECK_ERR(rmdir(p), ENOENT, "rmdir missing final component -> ENOENT");
+    CHECK_ERR(chroot(p), ENOENT, "chroot missing final component -> ENOENT");
+
+    join_path(p, sizeof(p), "missing-parent/child");
+    CHECK_ERR(mkdir(p, 0700), ENOENT, "mkdir missing parent -> ENOENT");
+    CHECK_ERR(mknod(p, S_IFIFO | 0600, makedev(0, 0)), ENOENT,
+              "mknod missing parent -> ENOENT");
+    CHECK_ERR(symlink("target", p), ENOENT, "symlink missing parent -> ENOENT");
+
+    join_path(p, sizeof(p), "file/child");
+    CHECK_ERR(mkdir(p, 0700), ENOTDIR, "mkdir non-directory parent -> ENOTDIR");
+    CHECK_ERR(mknod(p, S_IFIFO | 0600, makedev(0, 0)), ENOTDIR,
+              "mknod non-directory parent -> ENOTDIR");
+
+    join_path(p, sizeof(p), "file/");
+    CHECK_ERR(chdir(p), ENOTDIR, "chdir trailing slash on file -> ENOTDIR");
+
+    join_path(p, sizeof(p), "file");
+    join_path(q, sizeof(q), "file/renamed");
+    CHECK_ERR(rename(p, q), ENOTDIR, "rename non-directory destination parent -> ENOTDIR");
+}
+
+static void test_at_dirfd_and_flags(void)
+{
+    char abs_path[PATH_MAX];
+    int dfd = open(base, O_RDONLY | O_DIRECTORY);
+    CHECK(dfd >= 0, "open base dirfd");
+
+    CHECK_ERR(mkdirat(-1, "relative", 0700), EBADF,
+              "mkdirat relative path with invalid dirfd -> EBADF");
+    CHECK_ERR(mknodat(-1, "relative-fifo", S_IFIFO | 0600, makedev(0, 0)), EBADF,
+              "mknodat relative path with invalid dirfd -> EBADF");
+    CHECK_ERR(linkat(-1, "relative-src", dfd, "dst", 0), EBADF,
+              "linkat relative old path with invalid dirfd -> EBADF");
+    CHECK_ERR(unlinkat(-1, "relative", 0), EBADF,
+              "unlinkat relative path with invalid dirfd -> EBADF");
+
+    join_path(abs_path, sizeof(abs_path), "absolute-dirfd-ignored");
+    CHECK_RET(mkdirat(-1, abs_path, 0700), 0,
+              "mkdirat absolute path ignores invalid dirfd");
+    CHECK_RET(rmdir(abs_path), 0, "remove absolute mkdirat result");
+
+    CHECK_ERR(unlinkat(dfd, "missing", 0x80000000u), EINVAL,
+              "unlinkat invalid flags -> EINVAL");
+
+    int fd1 = openat(dfd, "rename2-src", O_CREAT | O_WRONLY | O_TRUNC, 0644);
+    int fd2 = openat(dfd, "rename2-dst", O_CREAT | O_WRONLY | O_TRUNC, 0644);
+    CHECK(fd1 >= 0 && fd2 >= 0, "create renameat2 files");
+    if (fd1 >= 0) {
+        close(fd1);
+    }
+    if (fd2 >= 0) {
+        close(fd2);
+    }
+    CHECK_ERR(do_renameat2(dfd, "rename2-src", dfd, "rename2-dst", 0x80000000u),
+              EINVAL, "renameat2 invalid flags -> EINVAL");
+    CHECK_ERR(do_renameat2(dfd, "rename2-src", dfd, "rename2-dst", RENAME_NOREPLACE),
+              EEXIST, "renameat2 RENAME_NOREPLACE existing dst -> EEXIST");
+
+    if (dfd >= 0) {
+        CHECK_RET(close(dfd), 0, "close base dirfd");
+    }
+}
+
+int main(void)
+{
+    TEST_START("SyscallGuard b001 path errno priority");
+    setup();
+    test_path_lengths();
+    test_lookup_errno_priority();
+    test_at_dirfd_and_flags();
+    rm_tree(base);
+    TEST_DONE();
+}
